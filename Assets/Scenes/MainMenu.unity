      m_Calls: []
  m_text: "Something is eating at you. It\u2019s the way he speaks, the way he dresses,
    and the fact that he has an apartment overlooking central park. You\u2019ve brought
    him here to finish this once and for all, but the competition is more persistent
    than you imagined.\n\nThis survival game is a high stakes interactive adaptation
    of the scene from American Psycho where Patrick Bateman kills Paul Allen with
    an Axe. To make it a proper game experience, I've turned a single execution into
    a battle against an endless stream of Paul Allen's.\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 834c53a8562310d4fbbfefab5b073123, type: 2}
  m_sharedMaterial: {fileID: -5505268246219199778, guid: 834c53a8562310d4fbbfefab5b073123, type: 2}
